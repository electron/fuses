  "compilerOptions": {
    "sourceMap": true,
    "noImplicitAny": true,
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "incremental": true
  },
  "include": ["src"]
}
